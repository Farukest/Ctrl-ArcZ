# Ctrl+ArcZ backend env. Copy to .env.local and fill in. NEVER commit real keys.
# All keys are server-only; they never reach a browser or the mobile bundle.

# Port the API listens on (behind nginx in production).
PORT=8787

# The enclave co-signer ("The Machine"). Signs Private Pay spends after the
# firewall + on-chain policy check. Throwaway testnet key only.
COSIGNER_PK=0x

# The demo relayer key that funds the CCTP/Gateway bridge and the gasless claim.
# Throwaway testnet key only.
RELAYER_PK=0x

# Circle Modular Wallets (gasless claim via Gas Station). Optional.
CIRCLE_CLIENT_KEY=
CIRCLE_CLIENT_URL=

# Comma-separated browser origins allowed to call the API (the web apps). Mobile
# has no Origin header and is always allowed. Empty allows any origin.
CORS_ORIGINS=https://ctrlarcz.xyz,https://www.ctrlarcz.xyz
