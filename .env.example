# Ctrl+ArcZ .env sablonu — kopyalayip .env yapin ve doldurun.
# Cuzdan uretmek icin: cast wallet new

RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002

DEPLOYER_ADDRESS=0x...
DEPLOYER_PRIVATE_KEY=0x...

SENDER_ADDRESS=0x...
SENDER_PRIVATE_KEY=0x...

RECEIVER_ADDRESS=0x...
RECEIVER_PRIVATE_KEY=0x...

# --- Demo apps (apps/sender/.env.local, apps/receiver/.env.local) ---
# A VITE_-prefixed value is only inlined into the CLIENT bundle if client code
# reads it via import.meta.env. VITE_RELAYER_PK / VITE_CLIENT_KEY / VITE_CLIENT_URL
# are read ONLY server-side (the /api/bridge and /api/gasless-claim Vite endpoints),
# so they never reach the browser. VITE_DEMO_PK is a dev-only test-wallet signer.
# Use throwaway Arc-testnet keys only, never real-value or mainnet keys. A prod
# build that would inline a key is refused unless VITE_ALLOW_DEMO_KEYS=1. See SECURITY.md.
#
# Sender (apps/sender/.env.local):
# VITE_DEMO_PK=0x...            # dev-only test-wallet signer (stands in for MetaMask)
# VITE_DEMO_RECEIVER=0x...      # address the poisoning demo crafts a lookalike of
# VITE_RECEIVER_URL=http://localhost:5174   # where claim links point
# VITE_BRIDGE_ENABLED=true      # non-secret flag; bridge signs server-side
#
# Receiver (apps/receiver/.env.local):
# VITE_DEMO_PK=0x...            # dev-only test-wallet signer
# VITE_RELAYER_PK=0x...         # server-only: gasless relayer / Circle account owner
# VITE_CLIENT_KEY=TEST_CLIENT_KEY:...:...   # server-only: Circle Modular Wallets client key
# VITE_CLIENT_URL=https://modular-sdk.circle.com/v1/rpc/w3s/buidl   # server-only: Circle RPC
# VITE_GASLESS_ENABLED=true     # non-secret flag; gasless signs server-side
#
# Both apps:
# VITE_ALLOW_DEMO_KEYS=1        # acknowledge throwaway keys may be present at build
