# Copy to .env and fill in. These are test keys for Arc testnet only — never
# commit real keys. The example reads them from the environment.

# Sender wallet private key (needs a little USDC for the transfer + gas).
SENDER_PK=0x...

# Recipient address, and the recipient wallet's private key (to run the claim).
RECIPIENT=0x...
RECIPIENT_PK=0x...

# Optional: amount in USDC (default 0.01).
# AMOUNT=0.01
