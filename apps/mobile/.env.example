# WalletConnect / Reown project id — a PUBLIC identifier (not a secret) from
# https://cloud.reown.com. Required for the "Connect wallet" picker to reach the
# WalletConnect relay; without it, connecting is a no-op.
EXPO_PUBLIC_WC_PROJECT_ID=

# Backend base URL. Defaults to the live API; override for local development, e.g.
# http://192.168.1.10:8788 (use your machine's LAN IP so the phone can reach it).
# EXPO_PUBLIC_API_BASE=https://api.ctrlarcz.xyz
